# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_KEY=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3-haiku

# Cron Security
CRON_SECRET=

# X API V2 (official, recommended)
# - X_CLIENT: "api" (default) | "playwright" (legacy fallback, ToS-violating)
# - X_BEARER_TOKEN: optional shared Bearer Token for the scraper.
#   Per-account Bearer Tokens (stored on the accounts row) take priority.
X_CLIENT=api
X_BEARER_TOKEN=

# GitHub Actions uses these as repository secrets:
# SUPABASE_URL, SUPABASE_KEY, OPENROUTER_API_KEY, OPENROUTER_MODEL,
# (optional) X_CLIENT, X_BEARER_TOKEN
