# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_KEY=
# Vercel-only (server side, RLS bypass for /api/cron/cycle)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (text + image generation)
# - OPENAI_TEXT_MODEL  : tweet / trend-analysis model (default gpt-4o-mini)
# - OPENAI_IMAGE_MODEL : companion image model        (default gpt-image-2)
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-2

# Cron Security (Bearer token required to invoke /api/cron/cycle)
CRON_SECRET=

# At-rest encryption for X API tokens (and the legacy x_password_enc column).
# 32 bytes hex-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# The same value must be set in Vercel + GitHub Actions Secrets, otherwise
# the worker cannot decrypt what the dashboard has written.
ENCRYPTION_KEY=

# X API V2 (official, recommended)
# - X_CLIENT: "api" (default) | "playwright" (legacy fallback, ToS-violating)
# - X_BEARER_TOKEN: optional shared Bearer Token for the scraper.
#   Per-account Bearer Tokens (stored on the accounts row) take priority.
X_CLIENT=api
X_BEARER_TOKEN=

# GitHub Actions uses these as repository secrets:
# SUPABASE_URL, SUPABASE_KEY, OPENAI_API_KEY, OPENAI_TEXT_MODEL,
# OPENAI_IMAGE_MODEL, ENCRYPTION_KEY,
# (optional) X_CLIENT, X_BEARER_TOKEN
